# Environment configuration for React Native app

# Lưu ý: Nếu chạy máy ảo Android, đổi localhost thành 10.0.2.2 ở file .env.local cá nhân

# API Configuration

EXPO_PUBLIC_API_URL=http://192.168.0.100:8080/api/v1
EXPO_PUBLIC_API_TIMEOUT=10000
EXPO_PUBLIC_AI_API_URL=http://192.168.0.100:8001
REACT_APP_API_URL=http://192.168.0.100:8080/api/v1
REACT_APP_API_TIMEOUT=10000
REACT_APP_AI_API_URL=http://192.168.0.100:8001

# Environment
NODE_ENV=development
REACT_APP_ENV=development

# Feature flags
REACT_APP_ENABLE_OFFLINE_MODE=true
REACT_APP_ENABLE_PUSH_NOTIFICATIONS=false

# Debug options
REACT_APP_DEBUG=true
REACT_APP_LOG_LEVEL=debug

# Google OAuth (Expo)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here
EXPO_PUBLIC_GOOGLE_REDIRECT_URI=https://auth.expo.io/@your-expo-username/your-app-slug
