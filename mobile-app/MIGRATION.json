    "navigation": {
      "from": "Flutter Navigation",
      "to": "React Navigation"
    },
    "persistentStorage": {
      "from": "Flutter Secure Storage",
      "to": "React Native Async Storage + redux-persist"
    }
  },
  "implementedFeatures": [
