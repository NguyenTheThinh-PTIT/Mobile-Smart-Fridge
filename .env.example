# ============================================================
# Environment Configuration Example
# ============================================================
# Copy this file to .env and customize for your environment
# docker-compose reads .env automatically
#
# Usage:
# cp .env.example .env
# docker-compose up -d
#
# ============================================================

# Database Configuration
POSTGRES_DB=fridge_ai
POSTGRES_USER=fridge_user
POSTGRES_PASSWORD=fridge_password
POSTGRES_PORT=5432

# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8080

# Database Connection Pool
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5

# JPA/Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_AI_FRIDGE=DEBUG

# Application Info
APP_NAME=Fridge AI Backend
APP_VERSION=1.0.0

# Gemini AI (do not hardcode secrets)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-1.5-flash

# Google OAuth (backend validation + Expo login metadata)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_PROJECT_ID=your_google_project_id_here
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_REDIRECT_URI=https://auth.expo.io/@your-expo-username/your-app-slug
GOOGLE_JAVASCRIPT_ORIGIN=http://localhost:8081

# Redis (if enabled)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# AI Service Configuration
AI_SERVICE_PORT=8001
AI_DATABASE_URL=postgresql+asyncpg://fridge_user:fridge_password@postgres:5432/fridge_ai
AI_REDIS_URL=redis://redis:6379/0
GEMINI_API_KEY=your_gemini_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here
EMBEDDING_MODEL=models/gemini-embedding-001
LLM_MODEL=gemini-2.5-flash
EMBEDDING_DIMENSION=3072
TOP_K_RETRIEVAL=20
WEATHER_CACHE_TTL_SECONDS=1800
SUGGESTION_CACHE_TTL_SECONDS=7200
EXPIRING_THRESHOLD_DAYS=3

# ============================================================
# Production Changes (DO NOT USE IN DEVELOPMENT)
# ============================================================
# 
# Change these for production:
# 
# # Use strong password
# POSTGRES_PASSWORD=your-secure-password-here
# 
# # Set to validate (don't auto-create schema)
# SPRING_JPA_HIBERNATE_DDL_AUTO=validate
# 
# # Set to WARN or ERROR
# LOGGING_LEVEL_ROOT=WARN
# LOGGING_LEVEL_COM_AI_FRIDGE=INFO
# 
# # Enable SSL/TLS
# # SERVER_SSL_ENABLED=true
# # SERVER_SSL_KEY_STORE=...
# 
# ============================================================
